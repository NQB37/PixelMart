model Address {
  id          String   @id @default(uuid())
  name        String
  phone       String
  userId      String
  addressLine String
  city        String
  country     String
  postalCode  String
  isDefault   Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("addresses")
}
