enum Gender {
  MALE
  FEMALE
  OTHER
}

model Profile {
  id          String   @id @default(uuid())
  userId      String   @unique
  name        String
  avatar      String?
  gender      Gender
  phone       String
  dateOfBirth DateTime
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("profiles")
}
